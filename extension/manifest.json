{
  "manifest_version": 3,
  "name": "Burner — fake signup identities",
  "version": "0.1.0",
  "description": "One click fills any signup form with a fake identity that stays consistent per site. Traceable emails show you who leaked your address. 100% local.",
  "permissions": ["storage", "activeTab", "scripting", "contextMenus", "clipboardWrite"],
  "background": { "service_worker": "background.js", "type": "module" },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": { "16": "icons/16.png", "32": "icons/32.png", "48": "icons/48.png", "128": "icons/128.png" },
    "default_title": "Burner — fill this page"
  },
  "icons": { "16": "icons/16.png", "32": "icons/32.png", "48": "icons/48.png", "128": "icons/128.png" },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Alt+Shift+B" },
      "description": "Open Burner"
    }
  }
}
